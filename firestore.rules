rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function adminDocument() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isEnabledAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && adminDocument().data.enabled == true;
    }

    function isSuperAdmin() {
      return isEnabledAdmin()
        && (
          !('role' in adminDocument().data)
          || adminDocument().data.role == 'super_admin'
        );
    }

    match /admins/{uid} {
      allow read: if isEnabledAdmin() && request.auth.uid == uid;
    }

    match /adminAuditLogs/{document} {
      allow read: if isSuperAdmin();
    }

    match /guildMembers/{docId} {
      allow read: if true;
      allow write: if isEnabledAdmin();
    }

    match /guildActivities/{docId} {
      allow read: if true;
      allow write: if isEnabledAdmin();
    }

    match /guildInfo/{docId} {
      allow read: if true;
      allow write: if isEnabledAdmin();
    }

    match /allianceInfo/{docId} {
      allow read: if true;
      allow write: if isEnabledAdmin();
    }

    match /bossInfo/{docId} {
      allow read: if true;
      allow write: if isEnabledAdmin();
    }

    match /guildAttendance/{docId} {
      allow read: if true;
      allow write: if isEnabledAdmin();
    }

    match /guildAttendanceSummary/{docId} {
      allow read: if true;
      allow write: if isEnabledAdmin();
    }

    match /bossNotifier/{docId} {
      allow read: if true;
      allow write: if isEnabledAdmin();
    }

    match /relicCalculator/{docId} {
      allow read: if true;
      allow write: if isEnabledAdmin();
    }

    match /marketplaceItems/{docId} {
      allow read: if true;
      allow write: if isEnabledAdmin();
    }

    match /appSettings/marketplacePricing {
      allow read: if true;
      allow write: if isEnabledAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
