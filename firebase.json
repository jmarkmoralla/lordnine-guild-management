{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": [
    {
      "source": "functions"
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/ocr-space",
        "function": "ocrSpaceProxy"
      },
      {
        "source": "/api/listAdmins",
        "function": "listAdmins"
      },
      {
        "source": "/api/createAdmin",
        "function": "createAdmin"
      },
      {
        "source": "/api/updateAdminRole",
        "function": "updateAdminRole"
      },
      {
        "source": "/api/updateAdminProfile",
        "function": "updateAdminProfile"
      },
      {
        "source": "/api/disableAdmin",
        "function": "disableAdmin"
      },
      {
        "source": "/api/deleteAdmin",
        "function": "deleteAdmin"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
